{
  "$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["src/**/*", "!node_modules", "!dist"]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useBlockStatements": "warn",
        "useConsistentMemberAccessibility": "error",
        "useConsistentArrayType": "error",
        "noInferrableTypes": "error",
        "noNamespace": "error",
        "useConsistentObjectDefinitions": "warn",
        "useNamingConvention": {
          "level": "error",
          "options": {
            "strictCase": false
          }
        }
      },
      "suspicious": {
        "noVar": "error",
        "noUnknownAtRules": "error"
      },
      "complexity": { "useArrowFunction": "error" }
    },
    "domains": {
      "react": "recommended"
    }
  },
  "css": {
    "linter": {
      "enabled": false
    }
  },
  "assist": {
    "enabled": false
  }
}
