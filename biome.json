{
  "$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!!**/src/components/ui/*",
      "!!**/node_modules",
      "!!**/dist",
      "!**/src/routeTree.gen.ts",
      "!**/src/styles/global.css"
    ]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useBlockStatements": "warn",
        "useConsistentMemberAccessibility": "error",
        "useConsistentArrayType": "error",
        "noInferrableTypes": "error",
        "noNamespace": "error",
        "useConsistentObjectDefinitions": "warn"
      },
      "suspicious": {
        "noVar": "error",
        "noUnknownAtRules": "error"
      },
      "complexity": { "useArrowFunction": "error" }
    },
    "domains": {
      "react": "recommended"
    }
  },
  "css": {
    "linter": {
      "enabled": false
    }
  },
  "assist": {
    "enabled": false
  },
  "overrides": [
    {
      "includes": [
        "src/features/bus/types.ts",
        "src/features/metro/types.ts",
        "src/features/bus/api.ts",
        "src/features/bus/utils.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    }
  ]
}
