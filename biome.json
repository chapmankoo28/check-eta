{
  "$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!!**/node_modules", "!!**/dist", "!!**/.astro"]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useBlockStatements": "warn",
        "useConsistentMemberAccessibility": "error",
        "useConsistentArrayType": "error",
        "noInferrableTypes": "error",
        "noNamespace": "error",
        "useConsistentObjectDefinitions": "warn",
        "useNamingConvention": "error"
      },
      "suspicious": {
        "noVar": "error",
        "noUnknownAtRules": "error"
      },
      "complexity": { "useArrowFunction": "error" }
    },
    "domains": {
      "react": "recommended"
    }
  },
  "css": {
    "linter": {
      "enabled": false
    }
  },
  "assist": {
    "enabled": false
  },
  "overrides": [
    {
      "includes": ["**/*.astro"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "off",
            "noUnusedVariables": "off"
          }
        }
      }
    }
  ]
}
