---
import { NavBar } from '@/components/NavBar'
import RootLayout from '@/layouts/RootLayout.astro'
import { Button } from '@cloudflare/kumo/components/button'
import { Empty } from '@cloudflare/kumo/components/empty'
import { HouseSimpleIcon, SealQuestionIcon } from '@phosphor-icons/react'
---

<RootLayout title="Page Not Found">
  <div class="flex flex-col justify-start space-y-10 h-screen">
    <NavBar client:only="react" />
    <div class="grid flex-1 place-content-center">
      <Empty
        icon={(<SealQuestionIcon size={48} />)}
        title="Page Not Found"
        description="The page you're looking for doesn't exist."
        contents={(
          <a href="/">
            <Button variant="primary" icon={HouseSimpleIcon} aria-label="Back to home page">
              Back to home page
            </Button>
          </a>
        )}
      />
    </div>
  </div>
</RootLayout>
