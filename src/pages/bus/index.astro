---
import NavBar from '@/components/NavBar.astro'
import { SearchBar } from '@/components/SearchBar'
import Main from '@/layouts/Main.astro'
import RootLayout from '@/layouts/RootLayout.astro'
import allRoutesData from '@/res/json/all_route_list.json'

const q = Astro.url.searchParams.get('q') || ''

const filteredRoutes = (q: string) => {
  if (q.trim().length === 0 || /^[^0-9a-zA-Z]+$/g.test(q)) {
    return []
  }
  return allRoutesData.data.filter((i) => {
    return i.route.toLowerCase().includes(q)
  })
}
---

<RootLayout>
  <div class="flex flex-col justify-start space-y-10">
    <NavBar />
    <Main className="max-w-none">
      <div>
        <SearchBar q={q} client:only="react" />
        {q.length !== 0 ? '搵唔到您輸入的路線' : '請輸入路線'}
      </div>
    </Main>
  </div>
</RootLayout>
